#include <WiFi.h>

const char* ssid = "_1057";
const char* password = "82190002";

void setup() {
  Serial.begin(115200);
  WiFi.begin(ssid, password);

  while (WiFi.status() != WL_CONNECTED) {
    delay(500);
    Serial.print(".");
  }

  Serial.println("\nПодключено к Wi-Fi");
  Serial.print("IP-адрес: ");
  Serial.println(WiFi.localIP());
}

void loop() {

}

